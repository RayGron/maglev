{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CLI: Build Debug",
      "type": "shell",
      "command": "cargo build",
      "group": "build",
      "problemMatcher": "$rustc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "CLI: Build Release",
      "type": "shell",
      "command": "cargo build --release",
      "group": "build",
      "problemMatcher": "$rustc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "CLI: Check",
      "type": "shell",
      "command": "cargo check",
      "group": "test",
      "problemMatcher": "$rustc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
