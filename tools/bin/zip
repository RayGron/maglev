#!/usr/bin/env python3

import pathlib
import sys
import zipfile


def iter_sources(source: pathlib.Path):
    if source.is_dir():
        for path in source.rglob("*"):
            if path.is_file():
                yield path, path.relative_to(source.parent)
    elif source.is_file():
        yield source, pathlib.Path(source.name)


def main(argv: list[str]) -> int:
    args = [arg for arg in argv[1:] if arg not in {"-q", "-r", "-X", "-y"}]
    if len(args) < 2:
        print("zip wrapper requires output archive and at least one input", file=sys.stderr)
        return 1

    archive_path = pathlib.Path(args[0])
    sources = [pathlib.Path(arg) for arg in args[1:]]
    archive_path.parent.mkdir(parents=True, exist_ok=True)

    with zipfile.ZipFile(archive_path, "w", compression=zipfile.ZIP_DEFLATED) as archive:
        for source in sources:
            for path, relative in iter_sources(source):
                archive.write(path, relative.as_posix())

    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
