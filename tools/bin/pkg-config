#!/usr/bin/env python3

import sys


def main(argv: list[str]) -> int:
    if "--version" in argv:
        print("0.29.2")
        return 0

    if "--print-errors" in argv and "--exists" in argv:
        return 0

    if "--exists" in argv:
        return 0

    if "--variable=pc_path" in argv:
        print("")
        return 0

    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
